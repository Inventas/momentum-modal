{
  "name": "inventas/momentum-modal",
  "description": "Build dynamic modal dialogs for your Inertia-powered Laravel apps",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Boris Lepikhin",
      "email": "boris@lepikhin.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "Momentum\\Modal\\": "src/",
      "Momentum\\Modal\\Tests\\": "tests/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Momentum\\Modal\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.0",
    "illuminate/support": "^8.24|^9.0|^10.0|^11.0|^12.0|^13.0",
    "inertiajs/inertia-laravel": "^0.6.9|^1.0|^2.0|^3.0"
  },
  "require-dev": {
    "orchestra/testbench": "^6.9.1|^7.0|^8.22|^9.0|^10.0|^11.0",
    "larastan/larastan": "^2.0|^3.0",
    "pestphp/pest": "^1.23|^2.34|^4.0",
    "pestphp/pest-plugin-laravel": "^1.4|^2.4|^4.0",
    "laravel/pint": "^0.1.3|^1.13"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Momentum\\Modal\\ModalServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
